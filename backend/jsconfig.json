{
	"compilerOptions": {
		"checkJs": true,
		"checkTs": false,
		"allowJs": true,
		"sourceMap": true,
		"skipLibCheck": true,
		"moduleResolution": "bundler",
		"allowImportingTsExtensions": true,
		"module": "esnext",
		"lib": ["esnext", "dom", "dom.iterable"],
		"paths": {
			"$lib": ["./src/lib"],
			"$lib/*": ["./src/lib/*"]
		}
	},
	"type": "module",
	"include": [
		".svelte-kit/ambient.d.ts",
		".svelte-kit/types/**/$types.d.ts",
		"src/**/*.js",
		"src/**/*.svelte"
	],
	"exclude": ["node_modules", ".svelte-kit", "build"]
}
